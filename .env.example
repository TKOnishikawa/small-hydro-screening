# 対象エリアの境界（minlon,minlat,maxlon,maxlat）
# 例: 中部広域 = 135.8,34.5,138.3,36.5
TARGET_BBOX=135.8,34.5,138.3,36.5

# 国土地理院 標高API（規約遵守のためレート制御必須）
GSI_API_RATE_LIMIT_SEC=1.0
GSI_API_BASE_URL=https://cyberjapandata2.gsi.go.jp/general/dem/scripts/getelevation.php

# 出力閾値（これ未満の候補は除外）
MIN_OUTPUT_KW=10
MIN_HEAD_M=2
